PORT=3000
HOST=0.0.0.0
DATA_DIR=./data

# Optional: protect write actions (/extract and /submit).
VELLUM_ACCESS_KEY=

# Optional: recommended when running behind Render or another reverse proxy.
TRUST_PROXY=true

# Optional: basic public-instance rate limiting.
RATE_LIMIT_WINDOW_MS=900000
EXTRACT_RATE_LIMIT_MAX=20
SUBMIT_RATE_LIMIT_MAX=30
